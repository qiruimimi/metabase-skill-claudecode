{
  "name": "kmb-model-builder",
  "version": "1.1.0",
  "description": "Metabase Model creation tool",
  "role": "atomic",
  "inputs": ["collection_id", "sql_file", "sql", "config_file", "name", "database"],
  "outputs": ["model_id", "validation_result"],
  "depends_on": ["kmb-sql-analyzer"],
  "reads": ["../agents/rules", "../scripts/lib/kmb"],
  "scripts": ["scripts/create_model.py"],
  "requires_env": ["KMB_API_KEY"],
  "default_database": 4
}
